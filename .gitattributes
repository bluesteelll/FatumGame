# ───────────────────────────────────────────────────────────────────────────────
# UNREAL ENGINE ASSETS
# ───────────────────────────────────────────────────────────────────────────────

# UE Asset files (binary, can be large)
*.uasset filter=lfs diff=lfs merge=lfs -text lockable
*.umap filter=lfs diff=lfs merge=lfs -text lockable

# UE Localization
*.locres filter=lfs diff=lfs merge=lfs -text

